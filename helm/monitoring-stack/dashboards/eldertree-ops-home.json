    {
      "id": 4,
      "type": "stat",
      "title": "Blackbox HTTPS (min probe_success)",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 8 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "min(probe_success{job=~\"blackbox-.*\"})"
        }
      ]
